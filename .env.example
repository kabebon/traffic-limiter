# ============================================================================
# traffic-limiter — autonomous orchestrator for Remnawave whitelist/basic quotas
# ============================================================================
# The service is fully standalone: it consumes the panel webhook directly and,
# when BOT_WEBHOOK_URL is empty, never talks to the bedolaga bot at all.
# Bot code is never modified — when enabled, the relay only calls the bot's
# existing /remnawave-webhook endpoint over HTTP (signed with HMAC-SHA256).

# ---- Required ----
REMNAWAVE_PANEL_URL=https://panel.example.com
REMNAWAVE_API_TOKEN=replace-me

# Shared secret used by the panel to HMAC-SHA256-sign the webhook body.
# MUST equal the panel's WEBHOOK_SECRET and (if relay is on) the bot's
# REMNAWAVE_WEBHOOK_SECRET. Minimum 32 chars.
WEBHOOK_SECRET_VALUE=replace-me-replace-me-replace-me

# Internal Squad UUIDs. Find them in the panel under Squads → Internal.
BASIC_SQUAD_UUID=00000000-0000-0000-0000-000000000001
WHITELIST_SQUAD_UUID=00000000-0000-0000-0000-000000000002

# Comma-separated UUIDs of the "basic" nodes whose per-user traffic feeds
# the basic counter. Find them in the panel under Nodes.
BASIC_NODE_UUIDS=00000000-0000-0000-0000-000000000010

# ---- Optional: bot relay (OFF by default) ----
# When set, processed events are forwarded to the bedolaga bot's webhook
# endpoint (its existing /remnawave-webhook) signed with BOT_WEBHOOK_SECRET.
# user.limited is translated to user.modified(status=ACTIVE) so the bot does
# NOT flip the subscription to "exhausted" when only the whitelist quota ran out.
# Leave empty for a fully standalone service.
BOT_WEBHOOK_URL=
BOT_WEBHOOK_SECRET=

# ---- Optional (defaults shown) ----
# Whitelist grace: whichever fires first ends the grace window.
WHITELIST_GRACE_WINDOW_SEC=3600
WHITELIST_GRACE_OVERLIMIT_MB=50

# Basic counter poll interval.
BASIC_POLL_INTERVAL_SEC=90
# Default per-user basic limit when seeing a user for the first time.
BASIC_DEFAULT_LIMIT_GB=20

# Storage / HTTP.
DB_PATH=/data/state.sqlite
HTTP_LISTEN=:8080
LOG_LEVEL=info

# Reconciliation safety-net interval.
RECONCILE_INTERVAL_SEC=300
# Outbound HTTP timeout for panel API calls.
HTTP_TIMEOUT_SEC=15

# External "user paid" trigger auth token (Bearer). Empty = endpoint disabled.
ADMIN_TOKEN=

# Optional Bearer auth on GET /api/state/{uuid}. Empty = open (use network ACLs).
STATE_API_TOKEN=

# ---- Optional: subscription proxy (Happ/INCY profile-title) ----
# When enabled, mount /sub/... that proxies panel subscriptions and rewrites
# the profile-title response header per-user based on whitelist state.
# Clients should point at this service's https://<host>/sub/{shortUuid} URL
# instead of the panel. Disabled by default.
SUBPROXY_ENABLED=false
SUBPROXY_CACHE_TTL_SEC=300
# Titles shown in the app header (Happ/INCY/v2rayNG). Plain text; emoji allowed.
WL_TITLE_ACTIVE=🟢 VPN · whitelist active
WL_TITLE_BLOCKED=⚠️ Whitelist exhausted · basic nodes work
# Title shown when the subscription is expired by date (panel status EXPIRED).
# In that case the subproxy serves the FAILOVER_CONFIG server instead of the
# panel body, so the user can still open the cabinet and renew.
WL_TITLE_EXPIRED=

# Single vless:// (or other supported scheme) link served to users whose
# subscription is expired by date. This is a rescue server that lets them
# reach the cabinet to renew — it is NOT served when the whitelist quota is
# exhausted (those users keep the basic nodes). Leave empty to disable the
# failover branch (expired users then get whatever the panel returns).
FAILOVER_CONFIG=vless://00000000-0000-0000-0000-000000000000@rescue.example.com:443?encryption=none&type=tcp&security=tls&sni=rescue.example.com#%F0%9F%87%B7%F0%9F%87%BA%20TELEGRAM

# Status messages shown to expired-by-date users as fake "server" lines before
# the rescue server (pipe-separated). Each entry becomes one readable line in
# the client's server list, mirroring how the panel renders placeholder lines.
FAILOVER_MESSAGES=⌛ Подписка истекла|Свяжитесь с поддержкой|Сервер для связи

# Branded Profile-Title shown to expired-by-date users (base64-encoded by the
# service, the format Happ/INCY/v2rayNG render cleanly).
FAILOVER_TITLE=KabebaVPN 🦉
